<div class="movie-details-container">
    <div class="movie-header">
        <div class="movie-poster">
            <img src="{{movie.posterurl}}" alt="Постер фильма {{movie.title}}">
            <span class="rating-badge-lg">{{movie.ratingavg}} ⭐</span>
            {{#if movie.agerestriction}}
                <div class="age-restriction-badge age-{{movie.agerestriction}}">
                    {{movie.agerestriction}}+
                </div>
            {{/if}}
        </div>

        <div class="movie-info">
            <div class="movie-title-group">
                <h1>{{movie.title}} ({{movie.releaseyear}})</h1>
                {{#if isAdmin}}
                    <a href="/admin/movies/{{movie.movieid}}/edit" class="btn btn-admin-edit" title="Редактировать фильм">
                        <i class="fas fa-edit"></i> Изменить
                    </a>
                {{/if}}
            </div>

            <div class="meta-data">
                <p><strong>Жанр:</strong> {{movie.genre}}</p>
                <p><strong>Режиссер:</strong> <a href="/director/{{movie.directorid}}" class="director-link">{{movie.directorname}}</a></p>
                <p><strong>Продолжительность:</strong> {{formatDuration movie.durationmin}}</p>
                {{#if movie.isactive}}
                    {{#if movie.price}}
                        <p><strong>Базовая цена билета:</strong> <span class="price-text">{{movie.price}} BYN</span></p>
                    {{/if}}
                {{/if}}
            </div>

            <!-- НОВЫЙ БЛОК ДЛЯ СТОРОННИХ РЕЙТИНГОВ -->
            <div class="external-ratings-block" data-movie-title="{{movie.title}}" data-movie-year="{{movie.releaseyear}}">
                <p><strong>Сторонние оценки:</strong></p>
                <div id="external-ratings-results">
                    <p class="loading-text">Загрузка рейтингов...</p>
                </div>
            </div>
            <!-- КОНЕЦ БЛОКА РЕЙТИНГОВ -->

            {{#if firstUpcomingScreening}}
                <div class="screening-info-block">
                    <p>
                        <strong>Ближайший сеанс:</strong>
                        {{formatDate firstUpcomingScreening.starttime}} (Зал: {{firstUpcomingScreening.hallname}})
                    </p>
                </div>
                <div class="movie-actions">
                    <a href="/movies/{{movie.movieid}}/select-time" class="btn btn-primary btn-lg">
                        Купить билет</a>
                </div>
            {{else}}
                <div class="alert alert-info movie-actions-placeholder">
                    Нет доступных сеансов для онлайн-покупки билетов.
                </div>
            {{/if}}
        </div>
    </div>

    <div class="movie-description-block">
        <h2>О фильме</h2>
        <p>{{movie.description}}</p>
    </div>

    {{#if movie.trailerId}}
        <div class="movie-video-block">
            <div class="video-switch-tabs">
                {{#if movie.onlineenabled}}
                    <button class="video-tab-btn {{#unless watchOnline}}active{{/unless}}" data-type="trailer">
                        <i class="fas fa-play-circle"></i>
                        <span>Трейлер</span>
                    </button>
                    <button class="video-tab-btn {{#if watchOnline}}active{{/if}}" data-type="movie">
                        <i class="fas fa-film"></i>
                        <span>Весь фильм</span>
                    </button>
                {{else}}
                    <div class="video-tab-btn active" style="cursor: default;">
                        <i class="fas fa-play-circle"></i>
                        <span>Трейлер</span>
                    </div>
                {{/if}}
            </div>

            <div class="video-container">
                <div id="trailerVideo" class="video-content {{#unless watchOnline}}active{{/unless}}">
                    <div class="video-wrapper">
                        <div class="trailer-iframe-container">
                            <iframe
                                    width="100%"
                                    height="100%"
                                    src="https://www.youtube.com/embed/{{movie.trailerId}}"
                                    frameborder="0"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                    allowfullscreen>
                            </iframe>
                        </div>
                    </div>
                </div>

                <!-- Фильм онлайн (только если доступен) -->
                {{#if movie.onlineenabled}}
                    <div id="movieVideo" class="video-content {{#if watchOnline}}active{{/if}}">
                        <div class="video-wrapper">
                            <video
                                    id="onlineMoviePlayer"
                                    controlsList="nodownload"
                                    poster="{{movie.posterurl}}"
                                    class="movie-video-player"
                                    preload="metadata"
                                    data-movie-id="{{movie.movieid}}"
                                    data-base-url="{{movie.onlineurl}}"
                            >
                                <source src="{{movie.onlineurl}}/master.m3u8" type="application/x-mpegURL">
                                Ваш браузер не поддерживает видео тег.
                            </video>

                            <!-- Кастомные контролы поверх видео -->
                            <div class="custom-video-controls">
                                <button class="control-btn play-pause-btn" title="Воспроизвести/Пауза">
                                    <i class="fas fa-play"></i>
                                </button>

                                <input type="range" class="progress-bar" min="0" max="100" value="0" step="0.1">

                                <div class="time-display">
                                    <span class="current-time">0:00</span> /
                                    <span class="total-time">0:00</span>
                                </div>

                                <div class="volume-container">
                                    <button class="control-btn volume-btn" title="Звук">
                                        <i class="fas fa-volume-up"></i>
                                    </button>
                                    <input type="range" class="volume-slider" min="0" max="1" step="0.1" value="1">
                                </div>

                                <div class="quality-selector">
                                    <button class="control-btn quality-btn" title="Качество видео">
                                        <i class="fas fa-hd"></i>
                                        <span class="current-quality">Auto</span>
                                    </button>
                                    <div class="quality-menu">
                                        <div class="quality-option" data-quality="auto">Авто</div>
                                        <div class="quality-option" data-quality="1080p">1080p</div>
                                        <div class="quality-option" data-quality="720p">720p</div>
                                        <div class="quality-option" data-quality="480p">480p</div>
                                        <div class="quality-option" data-quality="360p">360p</div>
                                    </div>
                                </div>

                                <button class="control-btn fullscreen-btn" title="Полный экран">
                                    <i class="fas fa-expand"></i>
                                </button>
                            </div>
                        </div>

                        <div class="video-info">
                            <div class="info-badge">
                                <i class="fas fa-clock"></i>
                                <span>{{formatDuration movie.durationmin}}</span>
                            </div>
                            <div class="info-badge quality-info">
                                <i class="fas fa-hd"></i>
                                <span class="current-quality-info">Авто</span>
                            </div>
                            {{#if movie.agerestriction}}
                                <div class="info-badge age-badge age-{{movie.agerestriction}}">
                                    <span>{{movie.agerestriction}}+</span>
                                </div>
                            {{/if}}
                        </div>
                    </div>
                {{/if}}
            </div>
        </div>
    {{/if}}

    {{#if movieShorts.length}}
        <div class="movie-shorts-block">
            <h2>🎬 Шортсы к фильму ({{movieShorts.length}})</h2>
            <div class="slider-container shorts-slider-container">
                <button class="slider-arrow slider-prev" data-target="shorts-slider">
                    &#10094;
                </button>

                <div class="shorts-grid slider-wrapper" id="shorts-slider">
                    {{#each movieShorts}}
                        <div class="short-card">
                            <a href="/shorts?movieid={{../movie.movieid}}#{{this.shortid}}" title="{{this.title}}">
                            <div class="short-placeholder-video">
                                <i class="material-icons">play_circle_filled</i>
                            </div>
                            <span class="short-duration">{{this.durationsec}} секунд</span>
                            </a>
                            <div class="card-info">
                                <h3>{{this.title}}</h3>
                            </div>
                        </div>
                    {{/each}}
                </div>

                <button class="slider-arrow slider-next" data-target="shorts-slider">
                    &#10095;
                </button>
            </div>
        </div>
    {{/if}}

    <!-- НОВЫЙ БЛОК ОТЗЫВОВ -->
    <div class="reviews-section" id="reviews-section">
        <h2>Отзывы зрителей</h2>

        {{#if (or movie.isactive movie.onlineenabled)}}
            {{#if error}}
                <div class="alert alert-error">{{error}}</div>
            {{/if}}
            {{#if success}}
                <div class="alert alert-success">{{success}}</div>
            {{/if}}

            {{#if isAuthenticated}}
                <div class="review-form-container">
                    {{#if currentUserReview}}
                        <h3>Ваш отзыв (Редактирование)</h3>

                        {{!-- Форма для редактирования --}}
                        <form action="/movies/{{movie.movieid}}/review" method="POST" id="edit-review-form">
                            <div class="form-group rating-group">
                                <label>Ваша оценка:</label>
                                <div class="star-rating-area">
                                    <input type="radio" id="star5-edit" name="rating" value="5" {{#ifeq currentUserReview.rating 5}}checked{{/ifeq}} required>
                                    <label for="star5-edit" title="5 Звезд"></label>
                                    <input type="radio" id="star4-edit" name="rating" value="4" {{#ifeq currentUserReview.rating 4}}checked{{/ifeq}}>
                                    <label for="star4-edit" title="4 Звезды"></label>
                                    <input type="radio" id="star3-edit" name="rating" value="3" {{#ifeq currentUserReview.rating 3}}checked{{/ifeq}}>
                                    <label for="star3-edit" title="3 Звезды"></label>
                                    <input type="radio" id="star2-edit" name="rating" value="2" {{#ifeq currentUserReview.rating 2}}checked{{/ifeq}}>
                                    <label for="star2-edit" title="2 Звезды"></label>
                                    <input type="radio" id="star1-edit" name="rating" value="1" {{#ifeq currentUserReview.rating 1}}checked{{/ifeq}}>
                                    <label for="star1-edit" title="1 Звезда"></label>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="reviewText-edit">Текст отзыва (до 500 символов):</label>
                                <textarea name="reviewText" id="reviewText-edit" rows="6" maxlength="500">{{currentUserReview.reviewtext}}</textarea>
                            </div>

                            <div class="review-edit-actions">
                                <button type="submit" class="btn btn-primary btn-sm">Обновить отзыв</button>
                            </div>
                        </form>

                        {{!-- Форма для удаления - ОТДЕЛЬНО и ВНЕ формы редактирования --}}
                        <form action="/movies/{{movie.movieid}}/review/delete" method="POST"
                              onsubmit="return confirm('Вы уверены, что хотите удалить свой отзыв и оценку? Это действие необратимо.');"
                              class="delete-user-review-form" style="margin-top: 10px;">
                            <button type="submit" class="btn btn-danger btn-sm">
                                <i class="fas fa-trash-alt"></i> Удалить отзыв
                            </button>
                        </form>

                    {{else}}
                        <h3>Оставить свой отзыв</h3>
                        <form action="/movies/{{movie.movieid}}/review" method="POST">
                            <div class="form-group rating-group">
                                <label>Ваша оценка:</label>
                                <div class="star-rating-area">
                                    <input type="radio" id="star5-new" name="rating" value="5" required>
                                    <label for="star5-new" title="5 Звезд"></label>
                                    <input type="radio" id="star4-new" name="rating" value="4">
                                    <label for="star4-new" title="4 Звезды"></label>
                                    <input type="radio" id="star3-new" name="rating" value="3">
                                    <label for="star3-new" title="3 Звезды"></label>
                                    <input type="radio" id="star2-new" name="rating" value="2">
                                    <label for="star2-new" title="2 Звезды"></label>
                                    <input type="radio" id="star1-new" name="rating" value="1">
                                    <label for="star1-new" title="1 Звезда"></label>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="reviewText-new">Текст отзыва (до 500 символов):</label>
                                <textarea name="reviewText" id="reviewText-new" rows="6" maxlength="500"></textarea>
                            </div>

                            <button type="submit" class="btn btn-primary">Опубликовать отзыв</button>
                        </form>
                    {{/if}}
                </div>

            {{else}}
                <div class="alert alert-info review-login-message">
                    <a href="/auth/login">Войдите</a>, чтобы оставить свой отзыв и оценку.
                </div>
            {{/if}}

        {{else}}
            <div class="alert alert-info review-login-message">
                Отзывы можно оставлять только на фильмы, находящиеся в прокате или доступные для онлайн-просмотра.
            </div>
        {{/if}}

        <!-- Список отзывов (показываем всегда, если они есть) -->
        <div class="reviews-list">
            {{#if currentUserReview}}
                <div class="review-item user-review-highlight">
                    <div class="review-header">
                        <span class="review-author">Вы</span>
                        <span class="review-rating">{{currentUserReview.rating}} ⭐</span>
                        <span class="review-date">{{formatDate currentUserReview.createdat}}</span>
                    </div>
                    <p class="review-text">{{currentUserReview.reviewtext}}</p>
                </div>
            {{/if}}

            <!-- 2. ОСТАЛЬНЫЕ ОТЗЫВЫ -->
            {{#each reviews}}
                <div class="review-item">
                    <div class="review-header">
                        <span class="review-author">{{this.nickname}}</span>
                        <span class="review-rating">{{this.rating}} ⭐</span>
                        <span class="review-date">{{formatDate this.createdat}}</span>

                        <!-- ДОБАВЛЕНИЕ КНОПКИ УДАЛЕНИЯ ДЛЯ АДМИНИСТРАТОРА -->
                        {{#if ../isAdmin}}
                            <div class="admin-review-actions">
                                <form action="/admin/reviews/{{this.reviewid}}/delete" method="POST" onsubmit="return confirm('Вы уверены, что хотите удалить этот отзыв административно?');">
                                    <button type="submit" class="btn-text-link" title="Удалить отзыв">
                                        Удалить
                                    </button>
                                </form>
                            </div>
                        {{/if}}
                    </div>
                    <p class="review-text">{{this.reviewtext}}</p>
                </div>
            {{else}}
                {{#unless currentUserReview}}
                    {{#if (or movie.isactive movie.onlineenabled)}}
                        <p class="no-reviews-message">Будьте первым, кто оставит отзыв на этот фильм!</p>
                    {{/if}}
                {{/unless}}
            {{/each}}
        </div>
    </div>
</div>

<style>
    :root {
        --progress: 0%;
    }

    /* Переопределения базовых стилей для страницы фильма */
    .movie-poster {
        height: 450px; /* Специфичная высота для страницы фильма */
        border-radius: 12px; /* Увеличенный радиус */
    }

    .movie-poster img {
        height: auto;
    }

    .rating-badge-lg {
        padding: 10px 15px; /* Увеличенный бейдж */
        font-size: 1.2rem;
        border-radius: 8px;
    }

    .age-restriction-badge {
        width: 60px;
        height: 60px;
        font-size: 1.5rem;
        border-width: 3px;
    }

    .btn-admin-edit {
        border-radius: 8px; /* Специфичный радиус */
        transition: all 0.3s ease;
    }

    .btn-admin-edit:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
    }

    .external-ratings-block {
        border: 2px dashed var(--border-color); /* Специфичный стиль */
        border-radius: 10px;
    }

    .external-rating-item {
        border-left: 4px solid var(--accent-primary); /* Специфичная полоска */
    }

    .screening-info-block {
        border-left: 4px solid var(--accent-primary); /* Специфичная полоска */
    }

    .btn-primary {
        border-radius: 8px; /* Специфичный радиус */
        transition: all 0.3s ease;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(229, 9, 20, 0.3);
    }

    .btn-danger:hover {
        transform: translateY(-2px);
    }

    .movie-description-block h2 {
        font-size: 28px; /* Специфичный размер */
        border-bottom: 2px solid var(--border-color);
    }

    .trailer-iframe-container {
        border-radius: 12px; /* Увеличенный радиус */
        box-shadow: 0 6px 25px var(--shadow-color);
    }

    .movie-shorts-block h2 {
        font-size: 28px;
        border-bottom: 2px solid var(--border-color);
    }

    .short-card {
        border-radius: 12px; /* Увеличенный радиус */
        height: 280px; /* Специфичная высота */
        flex: 0 0 160px;
        transition: transform 0.3s ease;
    }

    .short-card:hover {
        transform: translateY(-8px) scale(1.03);
        box-shadow: 0 12px 30px var(--shadow-color);
    }

    .short-placeholder-video {
        background: linear-gradient(135deg, var(--accent-primary), #333);
    }

    .short-card:hover .short-placeholder-video {
        background: linear-gradient(135deg, var(--accent-hover), #444);
    }

    .short-placeholder-video i {
        font-size: 60px;
        transition: transform 0.3s ease;
    }

    .short-card:hover .short-placeholder-video i {
        transform: scale(1.1);
    }

    .review-form-container {
        border-radius: 12px; /* Увеличенный радиус */
        box-shadow: 0 4px 20px var(--shadow-color);
    }

    .review-form-container h3 {
        font-size: 22px;
        border-bottom: 2px solid var(--border-color);
    }

    .star-rating-area label::before {
        font-size: 2.5rem; /* Увеличенные звезды */
    }

    .review-item {
        border-radius: 12px;
        transition: transform 0.3s ease;
    }

    .review-item:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 20px var(--shadow-color);
    }

    .review-rating {
        border-radius: 20px; /* Скругленный бейдж */
        padding: 4px 10px;
    }

    .btn-text-link:hover {
        background-color: rgba(220, 53, 69, 0.1);
    }

    /* ===== УНИКАЛЬНЫЕ КОМПОНЕНТЫ ===== */
    /* Переключатель вкладок над видео */
    .video-switch-tabs {
        display: flex;
        background: var(--bg-card);
        border-radius: 12px 12px 0 0;
        overflow: hidden;
        border-bottom: 2px solid var(--border-color);
        justify-content: flex-start;
        padding: 0 20px;
    }

    .video-tab-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 24px;
        background: none;
        border: none;
        color: var(--text-secondary);
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        border-bottom: 3px solid transparent;
        white-space: nowrap;
        min-width: 120px;
    }

    .video-tab-btn:hover {
        background: rgba(229, 9, 20, 0.05);
        color: var(--text-primary);
    }

    .video-tab-btn.active {
        color: var(--accent-primary);
        border-bottom-color: var(--accent-primary);
        background: rgba(229, 9, 20, 0.1);
    }

    .video-tab-btn i {
        font-size: 16px;
    }

    .video-container {
        position: relative;
        background: var(--bg-card);
        border-radius: 0 0 12px 12px;
        overflow: hidden;
    }

    .video-content {
        display: none;
        width: 100%;
    }

    .video-content.active {
        display: block;
    }

    /* Плеер для онлайн-фильма */
    .video-wrapper {
        position: relative;
        width: 100%;
        padding-top: 56.25%;
        background: #000;
    }

    .movie-video-player {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .video-wrapper:fullscreen .movie-video-player {
        object-fit: contain;
    }

    #trailerVideo .video-wrapper {
        padding-top: 0;
    }

    #trailerVideo .trailer-iframe-container {
        position: relative;
        width: 100%;
        padding-top: 56.25%;
        background: var(--bg-primary);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 6px 25px var(--shadow-color);
    }

    #trailerVideo .trailer-iframe-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
    }

    #movieVideo .video-wrapper:fullscreen {
        padding-top: 0;
    }

    #movieVideo .video-wrapper:fullscreen .movie-video-player {
        width: 100vw;
        height: 100vh;
        object-fit: contain;
    }

    #trailerVideo .video-wrapper:fullscreen {
        padding-top: 0;
    }

    #trailerVideo .video-wrapper:fullscreen .trailer-iframe-container {
        width: 100vw;
        height: 100vh;
        border-radius: 0;
    }

    #trailerVideo .video-wrapper:fullscreen .trailer-iframe-container iframe {
        width: 100vw;
        height: 100vh;
    }

    /* Кастомные контролы для видео */
    .custom-video-controls {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.9), rgba(0,0,0,0.7), transparent);
        padding: 15px 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease, visibility 0.3s ease;
        z-index: 100;
    }

    .video-wrapper.video-paused .custom-video-controls {
        opacity: 1;
        visibility: visible;
    }

    :fullscreen .custom-video-controls,
    :-webkit-full-screen .custom-video-controls,
    :-moz-full-screen .custom-video-controls {
        background: linear-gradient(to top, rgba(0,0,0,0.95), rgba(0,0,0,0.8));
        padding-bottom: 30px;
    }

    .movie-video-player:hover + .custom-video-controls,
    .custom-video-controls:hover {
        opacity: 1;
    }

    .control-btn {
        background: rgba(255, 255, 255, 0.9);
        border: none;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #333;
        font-size: 14px;
        transition: all 0.2s ease;
    }

    .control-btn:hover {
        background: white;
        transform: scale(1.1);
    }

    .progress-bar {
        flex: 1;
        height: 6px;
        -webkit-appearance: none;
        appearance: none;
        background: linear-gradient(to right,
        var(--accent-primary) 0%,
        var(--accent-primary) var(--progress, 0%),
        rgba(255, 255, 255, 0.2) var(--progress, 0%),
        rgba(255, 255, 255, 0.2) 100%
        );
        border-radius: 3px;
        outline: none;
        cursor: pointer;
        position: relative;
    }

