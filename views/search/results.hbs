<div class="page-container">
    <h1 class="page-title">
        {{#if searchQuery}}
            Результаты поиска "{{searchQuery}}"
        {{else}}
            Поиск
        {{/if}}
    </h1>

    {{#if searchQuery}}
        <div class="search-stats">
            <div class="stat-item">
                <span class="stat-value">{{movies.length}}</span>
                <span class="stat-label">фильмов</span>
            </div>
            <div class="stat-item">
                <span class="stat-value">{{directors.length}}</span>
                <span class="stat-label">режиссёров</span>
            </div>
        </div>
    {{/if}}

    {{!-- Режиссеры --}}
    {{#if directors.length}}
        <section class="search-section">
            <div class="section-header">
                <h2 class="section-title">
                    <i class="fas fa-video"></i>
                    Режиссёры
                </h2>
                <span class="section-count">{{directors.length}}</span>
            </div>

            <div class="directors-grid">
                {{#each directors}}
                    <a href="/director/{{this.directorid}}" class="director-card">
                        <div class="director-avatar">
                            <img src="{{this.photourl}}" alt="{{this.name}}"
                                 onerror="this.onerror=null;this.src='https://placehold.co/300x300/2c2c2c/f0f0f0?text=Нет+Фото';">
                        </div>
                        <div class="director-info">
                            <h3 class="director-name">{{this.name}}</h3>
                            {{#if this.biography}}
                                <p class="director-bio">{{trimString this.biography 100}}</p>
                            {{/if}}
                        </div>
                    </a>
                {{/each}}
            </div>
        </section>
    {{/if}}

    {{!-- Фильмы --}}
    {{#if movies.length}}
        <section class="search-section">
            <div class="filmography-header">
                <h2 class="section-title">
                    <i class="fas fa-film"></i>
                    Фильмы
                </h2>

                {{!-- Кнопки-фильтры (как у режиссёров) --}}
                <div class="filter-tabs">
                    <button class="filter-tab active" data-filter="all">
                        <span class="tab-icon">📽️</span>
                        Все фильмы
                        <span class="tab-count">{{movies.length}}</span>
                    </button>
                    <button class="filter-tab" data-filter="active">
                        <span class="tab-icon">🎬</span>
                        В прокате
                        <span class="tab-count">{{activeCount}}</span>
                    </button>
                    <button class="filter-tab" data-filter="online">
                        <span class="tab-icon">🌐</span>
                        Доступно онлайн
                        <span class="tab-count">{{onlineCount}}</span>
                    </button>
                    <button class="filter-tab" data-filter="upcoming">
                        <span class="tab-icon">⏳</span>
                        Скоро
                        <span class="tab-count">{{upcomingCount}}</span>
                    </button>
                </div>
            </div>

            <div class="movies-grid" id="movies-grid">
                {{#each movies}}
                    <div class="movie-card filter-item
                        {{#if this.isactive}}filter-active{{/if}}
                        {{#if this.onlineenabled}}filter-online{{/if}}
                        {{#if (and (not this.isactive) (not this.onlineenabled))}}filter-upcoming{{/if}}">

                        <a href="/movies/{{movieid}}" class="movie-card-link">
                            <div class="poster-container">
                                <img src="{{posterurl}}" alt="{{title}}" class="movie-poster">
                                {{#if agerestriction}}
                                    <div class="age-restriction-badge-small age-{{agerestriction}}">
                                        {{agerestriction}}+
                                    </div>
                                {{/if}}
                            </div>
                        </a>

                        <span class="rating-badge">{{ratingavg}} ⭐</span>

                        <div class="card-info">
                            <div>
                                <h3 class="movie-title">{{title}}</h3>
                                <p class="movie-genre">{{genre}} • {{formatDuration durationmin}}</p>
                                <p class="movie-director">{{directorname}}</p>

                                {{#if this.isactive}}
                                    <p class="status-text status-active">
                                        <i class="fas fa-play-circle"></i> В прокате
                                    </p>
                                {{else if this.onlineenabled}}
                                    <p class="status-text status-online">
                                        <i class="fas fa-globe"></i> Доступно онлайн
                                    </p>
                                {{else}}
                                    <p class="status-text status-upcoming">
                                        <i class="fas fa-clock"></i> Скоро
                                    </p>
                                {{/if}}
                            </div>
                        </div>

                        <div class="card-actions">
                            {{#if this.isactive}}
                                {{#if this.hassessions}}
                                    <a href="/movies/{{this.movieid}}/select-time" class="btn btn-primary btn-sm">
                                        <i class="fas fa-ticket-alt"></i> Билеты
                                    </a>
                                {{else}}
                                    <button class="btn btn-secondary btn-sm" disabled>Нет сеансов</button>
                                {{/if}}
                            {{else if this.onlineenabled}}
                                <a href="/movies/{{this.movieid}}?view=movie" class="btn btn-primary btn-sm">
                                    <i class="fas fa-play"></i> Смотреть
                                </a>
                            {{else}}
                                <button class="btn btn-secondary btn-sm" disabled>Скоро</button>
                            {{/if}}
                        </div>
                    </div>
                {{/each}}
            </div>
        </section>
    {{/if}}

    {{!-- Ничего не найдено --}}
    {{#unless movies.length}}
        {{#unless directors.length}}
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-search"></i>
                </div>
                <h3>Ничего не найдено</h3>
                <p>По вашему запросу <strong>"{{searchQuery}}"</strong> ничего не найдено</p>
                <div class="empty-actions">
                    <a href="/" class="btn btn-primary">На главную</a>
                    <button class="btn btn-secondary" onclick="window.history.back()">Назад</button>
                </div>
            </div>
        {{/unless}}
    {{/unless}}
</div>
<style>
    .page-container {
        padding: 20px;
        max-width: 1400px;
        margin: 0 auto;
        background-color: var(--bg-primary);
        color: var(--text-primary);
        min-height: calc(100vh - 200px);
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 600;
        margin-bottom: 40px;
        color: var(--text-primary);
        text-align: center;
        letter-spacing: -0.02em;
    }

    .page-title strong {
        color: var(--accent-primary);
        font-weight: 700;
    }

    /* Статистика поиска */
    .search-stats {
        display: flex;
        justify-content: center;
        gap: 40px;
        margin-bottom: 50px;
    }

    .stat-item {
        text-align: center;
    }

    .stat-value {
        display: block;
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--accent-primary);
        line-height: 1;
        margin-bottom: 5px;
    }

    .stat-label {
        font-size: 0.9rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Секции */
    .search-section {
        margin-bottom: 60px;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 25px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--border-color);
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 0;
    }

    .section-title i {
        color: var(--accent-primary);
        font-size: 1.3rem;
    }

    .section-count {
        background-color: var(--bg-card);
        color: var(--text-secondary);
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.9rem;
        font-weight: 500;
        border: 1px solid var(--border-color);
    }

    /* ===== КНОПКИ-ФИЛЬТРЫ ===== */
    .filter-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin: 20px 0 30px;
        background-color: var(--bg-card);
        padding: 10px;
        border-radius: 12px;
        border: 1px solid var(--border-color);
    }

    .filter-tab {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        border: none;
        border-radius: 8px;
        background-color: transparent;
        color: var(--text-secondary);
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
        flex: 0 1 auto;
    }

    .filter-tab:hover {
        background-color: var(--bg-input-focus);
        color: var(--text-primary);
    }

    .filter-tab.active {
        background-color: var(--accent-primary);
        color: white;
    }

    .filter-tab.active .tab-count {
        background-color: rgba(255, 255, 255, 0.2);
        color: white;
    }

    .tab-icon {
        font-size: 18px;
    }

    .tab-count {
        background-color: var(--bg-primary);
        color: var(--text-secondary);
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    /* Сетка режиссеров */
    .directors-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
    }

    .director-card {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 15px;
        background-color: var(--bg-card);
        border-radius: 12px;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s ease;
        border: 1px solid var(--border-color);
    }

    .director-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px var(--shadow-color);
        border-color: var(--accent-primary);
    }

    .director-avatar {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        overflow: hidden;
        flex-shrink: 0;
        background-color: var(--bg-primary);
        border: 2px solid var(--border-color);
    }

    .director-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .director-info {
        flex: 1;
        min-width: 0;
    }

    .director-name {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0 0 5px 0;
        color: var(--text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .director-bio {
        font-size: 0.85rem;
        color: var(--text-muted);
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.4;
    }

    /* ===== СЕТКА ФИЛЬМОВ ===== */
    .movies-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 30px;
        transition: opacity 0.3s ease;
    }

    .movies-grid.filtering {
        opacity: 0.7;
    }

    /* ===== КАРТОЧКА ФИЛЬМА ===== */
    .movie-card {
        background-color: var(--bg-card);
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 15px var(--shadow-color);
        transition: transform 0.3s ease, box-shadow 0.3s ease, opacity 0.3s ease;
        position: relative;
        display: flex;
        flex-direction: column;
        height: 100%;
        min-height: 420px;
    }

    .movie-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px var(--shadow-color);
    }

    .movie-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    /* Контейнер постера */
    .poster-container {
        position: relative;
        width: 100%;
        height: 350px;
        background-color: var(--bg-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .movie-poster {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
        transition: transform 0.3s ease;
        background-color: var(--bg-primary);
    }

    .movie-card:hover .movie-poster {
        transform: scale(1.02);
    }

    /* ===== БЕЙДЖИ ===== */
    .rating-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background: linear-gradient(135deg, var(--accent-primary), var(--accent-hover));
        color: white;
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: bold;
        font-size: 14px;
        z-index: 10;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.3);
    }

    .age-restriction-badge-small {
        position: absolute;
        top: 10px;
        left: 10px;
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 12px;
        color: white;
        z-index: 10;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.3);
        border: 2px solid white;
    }

    .age-0 { background-color: #4CAF50; }
    .age-6 { background-color: #2196F3; }
    .age-12 { background-color: #FF9800; }
    .age-16 { background-color: #F44336; }
    .age-18 { background-color: #000000; }

    /* ===== ОВЕРЛЕЙ ДЛЯ СКОРЫХ ПРЕМЬЕР ===== */
    .coming-soon-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.9));
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 5;
        pointer-events: none;
    }

    .coming-soon-overlay span {
        color: white;
        font-size: 1.5rem;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 2px;
        padding: 10px 20px;
        border: 2px solid white;
        border-radius: 8px;
        background-color: rgba(0, 0, 0, 0.5);
        transform: rotate(-5deg);
    }

    /* ===== ИНФОРМАЦИЯ О ФИЛЬМЕ ===== */
    .card-info {
        padding: 15px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        flex-grow: 1;
    }

    .movie-title {
        font-size: 1.2rem;
        margin: 0 0 8px 0;
        color: var(--text-primary);
        font-weight: 600;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        min-height: 2.6em;
    }

    .movie-genre {
        font-size: 0.9rem;
        color: var(--text-secondary);
        margin: 0 0 4px 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.4;
    }

    .movie-director {
        font-size: 0.85rem;
        color: var(--text-muted);
        margin: 0 0 8px 0;
        font-style: italic;
    }

    /* ===== СТАТУСЫ ===== */
    .status-text {
        font-size: 0.85rem;
        margin-top: 8px;
        display: flex;
        align-items: center;
        gap: 5px;
        font-weight: 500;
    }

    .status-active {
        color: var(--success-color);
    }

    .status-upcoming {
        color: var(--warning-color);
    }

    .status-online {
        color: var(--info-color);
    }

    .status-active i, .status-upcoming i, .status-online i {
        font-size: 14px;
    }

    /* ===== КНОПКИ ДЕЙСТВИЙ ===== */
    .card-actions {
        padding: 0 15px 15px 15px;
        margin-top: auto;
    }

    .btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 10px 15px;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        border: none;
        box-sizing: border-box;
    }

    .btn-sm {
        padding: 8px 12px;
        font-size: 0.85rem;
    }

    .btn-primary {
        background-color: var(--accent-primary);
        color: white;
    }

    .btn-primary:hover {
        background-color: var(--accent-hover);
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(229, 9, 20, 0.3);
    }

    .btn-secondary {
        background-color: var(--border-color);
        color: var(--text-primary);
    }

    .btn-secondary:hover:not(:disabled) {
        background-color: var(--border-light);
        transform: translateY(-2px);
    }

    .btn-secondary:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    /* Пустое состояние */
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        background-color: var(--bg-card);
        border-radius: 20px;
        border: 2px dashed var(--border-color);
    }

    .empty-icon {
        font-size: 4rem;
        color: var(--text-muted);
        margin-bottom: 20px;
    }

    .empty-icon i {
        font-size: 4rem;
    }

    .empty-state h3 {
        font-size: 1.8rem;
        font-weight: 600;
        margin: 0 0 10px 0;
        color: var(--text-primary);
    }

    .empty-state p {
        font-size: 1.1rem;
        color: var(--text-secondary);
        margin: 0 0 30px 0;
    }

    .empty-state p strong {
        color: var(--accent-primary);
        font-weight: 600;
    }

    .empty-actions {
        display: flex;
        gap: 15px;
        justify-content: center;
    }

    .empty-actions .btn {
        display: inline-flex;
        width: auto;
        min-width: 150px;
    }

    /* Адаптивность */
    @media (max-width: 1024px) {
        .movies-grid {
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 25px;
        }

        .poster-container {
            height: 300px;
        }
    }

    @media (max-width: 768px) {
        .page-title {
            font-size: 2rem;
        }

        .search-stats {
            gap: 20px;
        }

        .stat-value {
            font-size: 2rem;
        }

        .directors-grid {
            grid-template-columns: 1fr;
        }

        .filter-tabs {
            justify-content: center;
            flex-wrap: wrap;
        }

        .filter-tab {
            padding: 8px 12px;
            font-size: 13px;
        }

        .movies-grid {
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 20px;
        }

        .poster-container {
            height: 280px;
        }

        .movie-card {
            min-height: 400px;
        }

        .empty-actions {
            flex-direction: column;
            align-items: center;
        }
    }

    @media (max-width: 480px) {
        .page-title {
            font-size: 1.5rem;
        }

        .search-stats {
            flex-direction: column;
            gap: 10px;
        }

        .filter-tabs {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-tab {
            width: 100%;
            justify-content: center;
        }

        .movies-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .poster-container {
            height: 350px;
        }

        .movie-card {
            max-width: 300px;
            margin: 0 auto;
            min-height: 450px;
        }

        .empty-actions .btn {
            width: 100%;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const filterTabs = document.querySelectorAll('.filter-tab');
        const moviesGrid = document.getElementById('movies-grid');
        const movieCards = document.querySelectorAll('.movie-card');

        if (!filterTabs.length || !moviesGrid) return;

        // Функция для подсчета видимых карточек
        function updateVisibleCount() {
            const visibleCards = document.querySelectorAll('.movie-card:not([style*="display: none"])');
            const activeTab = document.querySelector('.filter-tab.active');

            if (activeTab) {
                const tabCount = activeTab.querySelector('.tab-count');
                if (tabCount) {
                    tabCount.textContent = visibleCards.length;
                }
            }
        }

        // Функция фильтрации
        function filterMovies(filterType) {
            moviesGrid.classList.add('filtering');

            setTimeout(() => {
                movieCards.forEach(card => {
                    switch(filterType) {
                        case 'all':
                            card.style.display = 'flex';
                            break;
                        case 'active':
                            if (card.classList.contains('filter-active')) {
                                card.style.display = 'flex';
                            } else {
                                card.style.display = 'none';
                            }
                            break;
                        case 'online':
                            if (card.classList.contains('filter-online')) {
                                card.style.display = 'flex';
                            } else {
                                card.style.display = 'none';
                            }
                            break;
                        case 'upcoming':
                            if (card.classList.contains('filter-upcoming')) {
                                card.style.display = 'flex';
                            } else {
                                card.style.display = 'none';
                            }
                            break;
                    }
                });

                moviesGrid.classList.remove('filtering');
                updateVisibleCount();
            }, 150);
        }

        // Обработчики кликов по кнопкам
        filterTabs.forEach(tab => {
            tab.addEventListener('click', function() {
                filterTabs.forEach(t => t.classList.remove('active'));
                this.classList.add('active');
                filterMovies(this.dataset.filter);
            });
        });

        // Инициализация счетчиков
        function initializeCounters() {
            const counts = {
                all: movieCards.length,
                active: document.querySelectorAll('.filter-active').length,
                online: document.querySelectorAll('.filter-online').length,
                upcoming: document.querySelectorAll('.filter-upcoming').length
            };

            filterTabs.forEach(tab => {
                const filterType = tab.dataset.filter;
                const countSpan = tab.querySelector('.tab-count');
                if (countSpan && counts[filterType] !== undefined) {
                    countSpan.textContent = counts[filterType];
                }
            });
        }

        initializeCounters();
    });
</script>